overviewText = "Recreation of the original Delta Force BHD mission";
overviewPicture = "overview.paa";
onLoadName = "Breakdown";
onLoadMission = "Escort the UN convoy to safety";
loadScreen = "dfbhd load.paa";

class CfgNotifications
{
	class Default
	{
		title = ""; // Tile displayed as text on black background. Filled by arguments.
		iconPicture = ""; // Small icon displayed in left part. Colored by "color", filled by arguments.
		iconText = ""; // Short text displayed over the icon. Colored by "color", filled by arguments.
		description = ""; // Brief description displayed as structured text. Colored by "color", filled by arguments.
		color[] = {1,1,1,1}; // Icon and text color
		duration = 5; // How many seconds will the notification be displayed
		priority = 0; // Priority; higher number = more important; tasks in queue are selected by priority
		difficulty[] = {}; // Required difficulty settings. All listed difficulties has to be enabled
	};
 
	// Examples
	class TaskAssigned
	{
		title = "TASK ASSIGNED";
		iconPicture = "\A3\ui_f\data\map\mapcontrol\taskIcon_ca.paa";
		description = "%1";
		priority = 6;
	};
	class civkilled
	{
		title = "Civilian Killed!";
		iconPicture = "\A3\ui_f\data\GUI\cfg\Debriefing\endDeath_ca.paa";
		description = "%1";
		color[] = {0.99,0.06,0.03,1};
		priority = 1;
	};
	class warning
	{
		title = "Warning";
		iconPicture = "\A3\ui_f\data\map\markers\military\warning_CA.paa";
		description = "%1";
		color[] = {0.92,0.93,0,1};
		priority = 7;
		duration = 10;
	};
	class civsafe
	{
		title = "Civilian Healed";
		iconPicture = "\A3\ui_f\data\GUI\cfg\hints\Incapacitated_ca.paa";
		description = "%1";
		color[] = {0.5,0.14,0.56,1};
		priority = 7;
		duration = 3;
	};
	class reward
	{
		title = "Reward";
		iconPicture = "\A3\ui_f\data\map\VehicleIcons\iconHelicopter_ca.paa";
		description = "%1";
		color[] = {0,0.97,0.1,1};
		priority = 1;
		duration = 4;
	};
	class reward2
	{
		title = "Reward";
		iconPicture = "\A3\ui_f\data\GUI\cfg\hints\Incapacitated_ca.paa"
		description = "%1";
		color[] = {0,0.97,0.1,1};
		priority = 2;
		duration = 4;
	};
};
class CfgMusic
{
  	tracks[]=
  	{
      		Marka, loop, heliride, win
  	};
 
