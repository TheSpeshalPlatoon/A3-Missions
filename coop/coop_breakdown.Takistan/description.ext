};
class CfgDebriefing
{  
	class SideLost
	{
		title = "Mission Failed";
		subtitle = "No more tickets left";
		description = "Your team died too much or too many civilians were killed";
		pictureBackground = "overview.paa";
		pictureColor[] = {0.99,0.02,0.01,1};
		picture = "KIA";
	};
	class loser
	{
		title = "Mission Failed: Team died";
		subtitle = "";
		description = "Everyone is dead and no respawn available.";
		pictureBackground = "overview.paa";
		picture = "KIA";
		pictureColor[] = {0.6,0.1,0.2,1};
	};
	class loser_UNdead
	{
		title = "Mission Failed";
		subtitle = "UN Truck destroyed";
		description = "You failed to escort the UN convoy to safety";
		pictureBackground = "overview.paa";
		picture = "";
		pictureColor[] = {0.6,0.1,0.2,1};
	};
	class end_unsafe
	{
		title = "Mission Completed";
		subtitle = "";
		description = "UN convoy is safe and is already distributing food and medical supplies to locals";
		pictureBackground = "overview.paa";
		picture = "";
		pictureColor[] = {0.0,0.3,0.6,1};
	};
};
