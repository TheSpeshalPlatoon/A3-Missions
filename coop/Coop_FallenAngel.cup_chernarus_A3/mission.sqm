													expression="_this setVariable ['Description',_value,true];";
													class Value
													{
														class data
														{
															singleType="STRING";
															value="<font face='PuristaBold' color='#fce300' size='15'>=== SITUATION ===</font>       " \n "<br/><br/>     " \n "Airborne infantry callsign Timberwolf was able to complete multiple objectives and secure a HVT but their ride home got shot down while trying to get out of the AO." \n "<br/><br/>" \n "Timberwolf managed to survive and by some miracle the HVT is still alive however, the pilots did not make it. stuck behind enemy lines, Your platoon lead calls for a secondary exfil." \n "<br/><br/>   " \n "High command says there's no available helis to provide exfil, best choice of action is to bunker down until a heli is able to be tasked. High command has tasked USAF to provide Air support." \n "<br/><br/>" \n "<font face='PuristaBold' color='#fce300' size='15'>=== Mission ===</font> " \n "<br/><br/> " \n "Head to the farm and Bunker down while USAF provides air cover, Expect to be besieged by majority of enemy forces." \n "<br/><br/>" \n "The HVT is still alive, Bring him with you if possible. If not then drop dead weight." \n "<br/><br/>" \n "Good Luck, High command out.";
														};
													};
												};
