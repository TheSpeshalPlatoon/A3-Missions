													property="ModuleCreateDiaryRecord_F_Description";
													expression="_this setVariable ['Description',_value,true];";
													class Value
													{
														class data
														{
															singleType="STRING";
															value="<font face='PuristaBold' color='#fce300' size='15'>=== SITUATION ===</font>       " \n "<br/><br/>     " \n "Airborne infantry callsign Timberwolf was able to complete multiple objectives and secure a HVT but their ride home got shot down while trying to get out of the AO." \n "<br/><br/> " \n "High command is tasking USAF Spectre to provide Timberwolf maximum amount of air support. Their behind enemy lines and no exfil can be called for them at this time. " \n "<br/><br/>" \n "High command has placed a location on the map for where Timberwolf can bunker down at. Be on standby until a heli can extract them." \n "<br/><br/>" \n "<font face='PuristaBold' color='#fce300' size='15'>=== Mission ===</font> " \n "<br/><br/> " \n "Provide support to Timberwolf, You are required to be on standby for constant attack runs until your bingo on ammo or fuel." \n "<br/><br/>" \n "Destroy the downed chinook, Prevent the enemy from scrapping the heli." \n "<br/><br/>" \n "Good Hunting, High command out.";
														};
													};
												};
