				class Item15
				{
					dataType="Logic";
					class PositionInfo
					{
						position[]={1443.728,4.5198789,2280.156};
						angles[]={0.020001473,3.6239491,0.01733112};
					};
					id=48;
					type="ModuleCreateDiaryRecord_F";
					class CustomAttributes
					{
						class Attribute0
						{
							property="ModuleCreateDiaryRecord_F_PresetTitle";
							expression="_this setVariable ['PresetTitle',_value,true];";
							class Value
							{
								class data
								{
									singleType="STRING";
									value="Situation";
								};
							};
						};
						class Attribute1
						{
							property="ModuleCreateDiaryRecord_F_Title";
							expression="_this setVariable ['Title',_value,true];";
							class Value
							{
								class data
								{
									singleType="STRING";
									value="RULES";
								};
							};
						};
						class Attribute2
						{
							property="ModuleCreateDiaryRecord_F_Description";
							expression="_this setVariable ['Description',_value,true];";
							class Value
							{
								class data
								{
									singleType="STRING";
									value="<font face='PuristaBold' color='#FF0000' size='15'>RULES</font><br/>          " \n "Five frags. Two fists. One glorious mission: eliminate your enemies in the name of politicians, investors, and questionable strategic objectives.<br/><br/>    " \n "<font face='PuristaBold' color='#00FF00' size='15'>EQUIPMENT</font><br/>          " \n "All players spawn equipped with:<br/>   " \n "- Full Brewster Armor<br/>   " \n "- Backpack containing:<br/>   " \n "5 × Frag Grenades<br/>   " \n "2 × Stun Grenades<br/>   " \n "2 × Dummy Grenades<br/>   " \n "1 × Smoke Grenade<br/><br/>   " \n "<font face='PuristaBold' color='#0000FF' size='15'>NOTES</font><br/>   " \n "Brewster Armor provides exceptional protection from explosions/shrapnel to the front. Flank your enemies and land grenades behind them for maximum effectiveness.<br/><br/>    " \n "The frags provided are very small and bouncy, take that into account when throwing.<br/><br/>    " \n "A direct charge against an opponent while holding a cooked grenade is highly unpredictable. Outcomes range from heroic success to immediate self-destruction.<br/><br/>    " \n "Stuns, dummies, and smoke are valuable tools for creating openings and forcing enemies out of position.<br/><br/>    " \n "Once you've exhausted your grenade supply, combat becomes significantly more personal. Your fists are now your primary weapon. <br/><br/>    " \n "<font face='PuristaBold' color='#fce300' size='15'>GUIDE FOR FRAGATHON</font><br/>   " \n "1. Get behind the enemy.<br/>  " \n "2. Throw grenade.<br/>   " \n "2a. Charge with live grenade.<br/>   " \n "3. If steps 2 and 2a fails, redo it until one of you dies.<br/>  " \n "4. If you have no grenades left, embrace violence with your bare hands.<br/>   " \n "5. Repeat until you are victorious.<br/>";
								};
							};
						};
						class Attribute3
						{
							property="ModuleCreateDiaryRecord_F_Owner";
							expression="_this setVariable ['Owner',_value,true];";
							class Value
							{
								class data
								{
									singleType="SCALAR";
									value=3;
								};
							};
						};
						class Attribute4
						{
							property="ModuleCreateDiaryRecord_F_Subject";
							expression="_this setVariable ['Subject',_value,true];";
							class Value
							{
