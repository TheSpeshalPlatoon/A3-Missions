										class data
										{
											singleType="STRING";
											value="Enemy forces consist of the Isla Pera National Military, a small force equipped largely with aging Soviet-era equipment.<br/><br/>" \n "" \n "Expect infantry supported by BMPs, light armored vehicles, and older air assets including MiG-21 fighters. Their equipment is outdated but still dangerous.<br/><br/>" \n "" \n "Morale within the ranks is reportedly low following the recent coup, and some units may surrender or abandon positions if faced with overwhelming force.";
