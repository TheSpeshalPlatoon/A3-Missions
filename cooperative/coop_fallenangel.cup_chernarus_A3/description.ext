author = "N1C0"; onLoadName = "Fallen Angel"; class Header {gameType = COOP}; loadScreen = __EVAL(selectRandom["overview.jpg"]); 

class CfgFunctions {class tsp_core {class functions {class init {file = "\tsp_core\initFramework.sqf"; preInit = true};};};};  //-- Addon mode needs full path (\tsp_core\)
#include "\a3\ui_f\hpp\definecommongrids.inc"
