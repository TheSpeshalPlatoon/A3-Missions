									property="ModuleCreateDiaryRecord_F_Description";
									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="The horizon islands are in a bloody civil war as the ruthless gang-turned-insurgency, Syndikat has challenged government troops on the islands on Tanoa.<br/><br/>    " \n "Syndikat managed to grow quickly and capture large chunks of territory from the HIDF, killing natives and tourists as they went.<br/><br/>    " \n "As for how Syndikat managed to pull of such an operation is unknown as they are typically poorly funded and organized. NATO suspects foreign involvement.<br/><br/>    " \n "Just recently, the HIDF has managed to corner Syndikat on SE corner of the mainland, however some Syndikat pushed into the ocean, capturing one of the oil rigs in the Darwin oil field.<br/><br/>    " \n "Luckily it only had a skeleton crew at the time. The crew of the other rigs have already been evacuated, but a boarding is required to rescure the 7 captives on the Atlas Bravo.";
										};
									};
								};
								class Attribute3
								{
									property="ModuleCreateDiaryRecord_F_Owner";
