									class Value
									{
										class data
										{
											singleType="STRING";
											value="The area of operations is controlled by Takistani insurgent forces, operating with a decentralized command structure but high local influence. <br/><br/>    " \n "They are well-entrenched in the mountainous and urban terrain surrounding Farabad and are equipped with small arms, RPGs, technicals, and improvised explosive devices (IEDs). <br/><br/>    " \n "Intel reports indicate the presence of veteran fighters with experience in asymmetrical warfare, capable of rapid ambushes and hit-and-run tactics. Expect fortified positions, patrols, and potential AA threats near strategic points.";
										};
									};
								};
