									property="ModuleCreateDiaryRecord_F_Description";
									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Task Force Saber is to infiltrate the AO under cover of darkness and execute the following objectives:<br/><br/>    " \n "- Kill or Capture Jalali Khara – Locate and eliminate or detain the HVT operating in Farabad. He is a Tier 1 priority target and may be heavily guarded.<br/><br/>    " \n "- Destroy Insurgent Weapon Caches – Confirm and destroy two identified weapons caches to cripple local supply chains.<br/><br/>    " \n "The area is classified as extremely hostile. Expect contact upon entry. Once both objectives are complete, all elements are to extract immediately to the designated LZ. Prolonged presence in the AO is not advised due to risk of encirclement or QRF from surrounding insurgent-held villages.";
										};
									};
								};
								class Attribute3
								{
									property="ModuleCreateDiaryRecord_F_Owner";
									expression="_this setVariable ['Owner',_value,true];";
