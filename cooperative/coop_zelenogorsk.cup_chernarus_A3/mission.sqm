									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="- Recapture MB Zelenogorsk from the ChDKZ and rescue and render aid to any surviving CDF personnel.<br/><br/>     " \n " " \n "- CDF reports a heavy concentration of ChDKZ forces at the school in Zelenogorsk, neutralise all ChDKZ forces and secure the school.<br/><br/>     " \n " " \n "- Find and rescue a USMC squad was stationed in MB Zelenogorsk, as per the last radio contact with the squad, they are five strong and fled into Zelenogorsk actual.<br/><br/>     " \n " " \n "- Recapture Green Mountain from the ChDKZ and rescue and render aid to any surviving CDF personnel.";
										};
									};
								};
