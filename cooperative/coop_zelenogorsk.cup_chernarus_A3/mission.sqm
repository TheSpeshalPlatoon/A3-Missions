									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="The ChDKZ have struck a deal with the Russian Federation to back their military actions against the Chernarussian government, to that end, the Russian Federation have supplied the ChDKZ with small arms, munitions and armoured vehicles.<br/><br/>    " \n "We suspect that they will be using Soviet-era weapons and vehicles, ranging from BMPs to MBTs.";
