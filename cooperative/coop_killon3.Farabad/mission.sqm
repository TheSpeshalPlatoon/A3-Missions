								class Attribute2
								{
									property="ModuleCreateDiaryRecord_F_Description";
									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Syndikat can be identified by wearing a jungle uniform most of the time, but have been known to wear civilian clothing as well.<br/><br/>   " \n "There are 2 Syndikat cells located in the AO, Solomon's army which is organised and well armed, and Bari Molia's group of ex-cartel members with extremist values. " \n "Syndikat usually operate civilian vehicles or technicals, but have been seen with BRDMs and BTRs lately.<br/><br/>   " \n "The ROE is loose, anyone with a weapon can be considered hostile.   " \n "";
										};
									};
								};
								class Attribute3
								{
									property="ModuleCreateDiaryRecord_F_Owner";
