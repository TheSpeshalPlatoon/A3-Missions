													singleType="STRING";
													value="Situation";
												};
											};
										};
										class Attribute1
										{
											property="ModuleCreateDiaryRecord_F_Title";
											expression="_this setVariable ['Title',_value,true];";
											class Value
											{
												class data
												{
													singleType="STRING";
													value="";
												};
											};
										};
										class Attribute2
										{
											property="ModuleCreateDiaryRecord_F_Description";
											expression="_this setVariable ['Description',_value,true];";
											class Value
											{
												class data
												{
													singleType="STRING";
													value="<font face='PuristaBold' color='#fce300' size='15'>=== SITUATION ===</font>        " \n "<br/><br/> " \n "The civil war in chernarus has gotten worse. Northern towns has fallen into chDKZ control, CDF has many deserters and major grounds was lost. The Russians are actively assisting the chDKZ by providing them information and supply. The entirety of Chernarus fell into chDKZ and the possibility of Russians pushing into chernarus is high." \n "<br/><br/> " \n "Most of the US troops stationed in Chernarus have been forced back or captured by the chDKZ. The US responded by deploying its naval and amphibious fleet towards the green sea. " \n "<br/><br/> " \n "USS Takmyr along with 2 Cruisers are deployed towards the North Eastern region of Chernarus. CENTCOM has tasked 1st Force Recon alongside 3rd Marine Raider Battalion with securing Svetloyarsk by acting as the spearhead." \n "<br/><br/>   " \n "<font face='PuristaBold' color='#fce300' size='15'>=== MISSION ===</font>  " \n "<br/><br/>  " \n "Your task force is sent in first to secure a beachhead for the rest." \n "<br/><br/>" \n "Your main objectives are as follows, Securing Svet and the road leading into Novo, Eliminating HVT within the town, Destroying enemy assets, Destroy communication tower." \n "<br/><br/>" \n "Side objectives are ensuring any hostile assets facing the port is destroyed. it'll increase the chances for our AAVPs to beach and LCACs to drop off assets. " \n "<br/><br/>" \n "Your success may determine if we can get boots on the ground without mass casualties and if we can get our hands on krasno Airfield. " \n "<br/><br/>" \n "good luck,  High Command out.";
												};
											};
										};
