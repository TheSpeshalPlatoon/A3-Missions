										class Attribute2
										{
											property="ModuleCreateDiaryRecord_F_Description";
											expression="_this setVariable ['Description',_value,true];";
											class Value
											{
												class data
												{
													singleType="STRING";
													value="<font face='PuristaBold' color='#fce300' size='15'>=== SITUATION ===</font>         " \n "<br/><br/>  " \n "The civil war in chernarus has gotten worse. Northern towns has fallen into chDKZ control, CDF has many deserters and major grounds was lost. The Russians are actively assisting the chDKZ by providing them information and supply. The entirety of Chernarus fell into chDKZ and the possibility of Russians pushing into chernarus is high. " \n "<br/><br/>  " \n "Most of the US troops stationed in Chernarus have been forced back or captured by the chDKZ. The US responded by deploying its naval and amphibious fleet towards the green sea.  " \n "<br/><br/> " \n "USS Takmyr and USS khe sanh and 4 Arleigh Burke destroyers towards the North Eastern region of Chernarus. CENTCOM has greenlit a ground invasion. " \n "<br/><br/>    " \n "<font face='PuristaBold' color='#fce300' size='15'>=== MISSION ===</font>   " \n "<br/><br/>   " \n "Your task force is being sent in for a ground invasion. " \n "<br/><br/> " \n "Your main objectives are: " \n "<br/> " \n "Securing Svetloyarsk " \n "<br/> " \n "Krasnostav airfield " \n "<br/> " \n "Novodmitrovsk " \n "<br/><br/> " \n "There will be multiple sub objectives in this operation. Once you've taken one main objective, We will provide new Objectives.  " \n "<br/><br/> " \n "good luck,  High Command out.";
												};
											};
										};
