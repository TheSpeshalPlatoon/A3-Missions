						class Item0
						{
							dataType="Logic";
							class PositionInfo
							{
								position[]={1927.165,1.22,3933.752};
							};
							id=24;
							type="ModuleCreateDiaryRecord_F";
							class CustomAttributes
							{
								class Attribute0
								{
									property="ModuleCreateDiaryRecord_F_PresetTitle";
									expression="_this setVariable ['PresetTitle',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Situation";
										};
									};
								};
								class Attribute1
								{
									property="ModuleCreateDiaryRecord_F_Title";
									expression="_this setVariable ['Title',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Briefing";
										};
									};
								};
								class Attribute2
								{
									property="ModuleCreateDiaryRecord_F_Description";
									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="<font face='PuristaBold' color='#fce300' size='15'>SITUATION</font> " \n "<br/> " \n "An Astra Aerospace representative is currently on Isla Pera to conduct a series of high profile meetings related to ongoing corporate operations in the region. Due to the dangerous nature of the visit, Astra has contracted ION Services to provide a dedicated security detail for the duration of the representative's stay. " \n "<br/><br/> " \n "Intelligence indicates that a rival private military company has deployed personnel across the island and may attempt to disrupt Astra's activities, gather intelligence, or eliminate the representative altogether. " \n "<br/><br/> " \n "The representative's exact itinerary remains flexible and will be determined on the ground as new information becomes available. " \n "<br/><br/> " \n "<font face='PuristaBold' color='#fce300' size='15'>ENEMY</font> " \n "<br/> " \n "Elements of a rival PMC are operating throughout Isla Pera. Their strength, disposition, and objectives remain unclear. " \n "<br/><br/> " \n "Expect hostile patrols, roadblocks, surveillance teams, and quick reaction forces near key locations of interest. " \n "<br/><br/> " \n "The longer the representative remains active on the island, the greater the likelihood of enemy interference. " \n "<br/><br/> " \n "<font face='PuristaBold' color='#fce300' size='15'>MISSION</font> " \n "<br/> " \n "Task Force Stone is to rendezvous with the Astra representative at <marker name='marker_1'>the city meeting point</marker>. " \n "<br/><br/> " \n "Once contact has been established, the representative will assume operational authority regarding the itinerary. Follow his instructions and escort him safely to all required destinations. " \n "<br/><br/> " \n "Maintain close protection of the VIP at all times. Respond to emerging threats as necessary and ensure the representative is able to complete all requested objectives.";
										};
									};
								};
								class Attribute3
								{
									property="ModuleCreateDiaryRecord_F_Owner";
									expression="_this setVariable ['Owner',_value,true];";
									class Value
									{
										class data
										{
											singleType="SCALAR";
											value=3;
										};
									};
								};
								class Attribute4
