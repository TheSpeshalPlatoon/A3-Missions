								class Attribute2
								{
									property="ModuleCreateDiaryRecord_F_Description";
									expression="_this setVariable ['Description',_value,true];";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="<font face='PuristaBold' color='#fce300' size='15'>SITUATION</font>  " \n "<br/>  " \n "43 hours ago, two Astra Aerospace reentry capsules unexpectedly came down near the Serbian-Kosovo border following a guidance system malfunction during atmospheric recovery. The capsules were supposed to land in a designated recovery zone on the lake near Rezallë, Kosovo.  " \n "<br/><br/>  " \n "Serbian authorities seized both capsules, claiming they were used as espionage systems targeting Serbian military installations.  " \n "<br/><br/>  " \n "Astra has privately contracted ION Services to recover all sensitive mission hardware before Serbian forces can transport them deeper into the country for exploitation.  " \n "<br/><br/>  " \n "Task Force Stone has been assembled to conduct a recovery operation by force.  " \n "<br/><br/>  " \n "<font face='PuristaBold' color='#fce300' size='15'>ENEMY</font>  " \n "<br/>  " \n "Elements of the Serbian Armed Forces maintain control of the AO and have established checkpoints along major roads and border crossings.  " \n "<br/><br/>  " \n "Once you've caused enough chaos, rapid-response units will be dispatched to destroy your force.  " \n "<br/><br/>  " \n "<font face='PuristaBold' color='#fce300' size='15'>MISSION</font>  " \n "<br/>  " \n "You are to advance north towards the capsules' last known location and recover both the <marker name='marker_7'>GPS Data</marker> and <marker name='marker_5'>Flight Data Recorder</marker> case. Ensure both cases are carried safely and DO NOT leave them behind.  " \n "<br/><br/>  " \n "Once both objectives have been recovered, move immediately to the <marker name='marker_9'>airfield</marker> for extraction before Serbian reinforcements can isolate the AO. " \n "<br/><br/> " \n "ION Aviation Services will provide CAS as well as your ride out of here. ";
										};
									};
								};
								class Attribute3
								{
									property="ModuleCreateDiaryRecord_F_Owner";
